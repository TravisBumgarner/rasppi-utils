{
  "name": "social-poster",
  "private": true,
  "scripts": {
    "postinstall": "npm --prefix web install",
    "dev": "node dev.mjs",
    "dev:no-tunnel": "concurrently -k -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "../.venv/bin/python scripts/server.py",
    "dev:web": "npm --prefix web run dev",
    "build": "npm --prefix web run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
