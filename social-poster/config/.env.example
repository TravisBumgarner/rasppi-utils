# Social Poster configuration
# Port for the web UI / API server
PORT=5050

# Where images and the SQLite database are stored.
# Leave as-is; the systemd units set this to a persistent path.
# DATA_DIR=/var/lib/rasppi-utils/social-poster

# Required for Instagram. The Graph API fetches photos from a public URL, so
# this app's /images endpoint must be reachable publicly — point a Cloudflare
# Tunnel at this app and put its https domain here (no trailing slash).
PUBLIC_BASE_URL=https://poster.travisbumgarner.photography

# PUBLIC_BASE_URL is exposed by a named Cloudflare Tunnel (no token needed here).
# One-time setup, run on the Pi:  social-poster/setup-cloudflare.sh
# It creates the tunnel + DNS record and points it at this app. Bluesky works
# without it; only Instagram needs the public URL.

# Dev safety switch. 1 = simulate posting (never send to Instagram/Bluesky),
# 0 = live. Anything other than 1 is treated as live. Set 0 in prod.
DRY_RUN=0
