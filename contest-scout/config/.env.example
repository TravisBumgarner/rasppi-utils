# Claude Code credentials — set ONE of these.
# Preferred: a long-lived subscription token. Generate on any machine with
#   claude setup-token
# and paste the result here (uses your Claude subscription, no API billing).
CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token
# Alternative: an Anthropic API key (pay-per-token billing).
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: full path to the claude binary if it's not on systemd's PATH
# (find it with: which claude).
# CLAUDE_BIN=/usr/local/bin/claude

# Optional: override the notification relay (defaults to the contact-form
# service the portfolio sites use).
# CONTACT_FORM_URL=https://contact-form.nfshost.com/contact
